# ============================================================
# .env.drone.example
# Biến môi trường cho Drone Edge Server
# Sao chép thành .env.drone rồi điền giá trị thực
#   cp .env.drone.example .env.drone
# ============================================================

# ── API Authentication ────────────────────────────────────────
# Key để Raspberry Pi xác thực với Edge Server
# Đổi thành chuỗi ngẫu nhiên mạnh khi deploy thực tế
CLIENT_API_KEY=drone-secret

# ── Whisper STT ───────────────────────────────────────────────
# Model size: tiny (~40MB, ~200ms) | small (~250MB, ~300ms) | medium (chậm hơn)
# Dùng tiny hoặc small cho latency thấp (<500ms) — đủ cho lệnh ngắn UAV
WHISPER_MODEL=small

# Device: cpu (cho máy không có GPU) | cuda (nếu có NVIDIA GPU)
WHISPER_DEVICE=cpu

# Quantization: int8 (CPU, tiết kiệm RAM, nhanh 2-4x) | float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# ── NLLB Translation ─────────────────────────────────────────
# Dùng để dịch lệnh tiếng Việt → tiếng Anh trước khi phân loại intent
# 600M: nhanh, nhẹ | 1.3B: chính xác hơn nhưng chậm hơn
NLLB_MODEL=facebook/nllb-200-distilled-600M

# ── Ollama LLM ───────────────────────────────────────────────
# Model dùng để phân loại intent (LLM Fallback khi Regex không match)
# llama3:8b (mặc định) | gemma3:9b | phi3:mini (nhẹ hơn)
LLM_MODEL=llama3:8b

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
