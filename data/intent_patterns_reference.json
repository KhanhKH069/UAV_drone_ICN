{
  "meta": {
    "description": "UAV English 28-intent rule-based pattern reference",
    "version": "v2.0",
    "total_intents": 28,
    "groups": [
      "Câu hỏi (Q01-Q05)",
      "Điều khiển bay (I12-I16)",
      "Quay hướng (I07-I11)",
      "Điều hướng (I17-I20)",
      "Di chuyển (I01-I06, A01)",
      "Nông nghiệp (A02-A04)"
    ],
    "priority_note": "Apply patterns in listed order — first match wins. Question intents (Q*) only apply when source='question'.",
    "language": "en",
    "note": "All patterns are English-only. Vietnamese tokens removed from A02-A04 regexes. navigate_general (259 corpus samples) has no assigned pattern — pending v2.1. Zero-sample intents (hover, descend, spray_zone, map_area, mark_anomaly) have patterns ready for future data collection."
  },
  "patterns": [
    {
      "intent": "ask_direction",
      "id": "Q01",
      "group": "Câu hỏi",
      "regex": "\\b(which direction|what direction|where should i go|how to go|where.*go now)\\b",
      "dataset_count": "~2582",
      "example": "which direction should I go?"
    },
    {
      "intent": "ask_destination_appearance",
      "id": "Q02",
      "group": "Câu hỏi",
      "regex": "\\b(what.*destination look|how does.*destination|destination.*color|destination.*shape)\\b",
      "dataset_count": "~319",
      "example": "what does the destination look like?"
    },
    {
      "intent": "ask_proximity",
      "id": "Q03",
      "group": "Câu hỏi",
      "regex": "\\b(am i (near|close|at)|how far|am i (almost|nearly)|near the destination)\\b",
      "dataset_count": "~23",
      "example": "am I near the destination?"
    },
    {
      "intent": "ask_visibility",
      "id": "Q04",
      "group": "Câu hỏi",
      "regex": "\\b(can i see|is.*in (my )?view|in.*field of view|is.*visible|do i see)\\b",
      "dataset_count": "~40",
      "example": "can I see the destination?"
    },
    {
      "intent": "ask_current_position",
      "id": "Q05",
      "group": "Câu hỏi",
      "regex": "\\b(i am (on|at|in|near)|i('m| am) (on top|on the|at the)|i (move|moved|pass|passed|turn))\\b",
      "dataset_count": "~46",
      "example": "I am on the brown building at 8 o'clock"
    },
    {
      "intent": "take_off",
      "id": "I12",
      "group": "Điều khiển bay",
      "regex": "\\b(take off|takeoff|lift off|launch|take flight|depart)\\b",
      "dataset_count": "~1",
      "example": "take off to first floor height"
    },
    {
      "intent": "land",
      "id": "I13",
      "group": "Điều khiển bay",
      "regex": "\\b(land|landing|touch down|set down|descend and land)\\b",
      "dataset_count": "~76",
      "example": "land on lower roof"
    },
    {
      "intent": "hover",
      "id": "I14",
      "group": "Điều khiển bay",
      "regex": "\\b(hover|hold position|hold altitude|stay in place|maintain (position|altitude)|wait here)\\b",
      "dataset_count": "0",
