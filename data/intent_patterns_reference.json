      "regex": "\\b(return (to )?home|go home|come back|rtl|return to base|fly back)\\b",
      "dataset_count": "~3",
      "example": "return home, RTL"
    },
    {
      "intent": "rotate_degrees",
      "id": "I11",
      "group": "Quay hướng",
      "regex": "\\b(turn|rotate|spin)\\b.*\\b\\d+\\s*degree|\\b\\d+\\s*degree.*\\b(turn|rotate)",
