# ============================================================
# Paraline Drone Edge Server — Environment Configuration
# Copy: cp .env.example .env  then chỉnh sửa theo hệ thống VMG
# ============================================================

# --- Network (VMG_STAFF LAN) ---
VMG_SERVER_IP=127.0.0.1

# --- Security (THAY ĐỔI TRƯỚC KHI DEPLOY!) ---
ADMIN_API_TOKEN=CHANGE_ME_RANDOM_32_CHARS_MINIMUM_LENGTH
CLIENT_API_KEY=paraline_client_secret_key_local
DB_PASSWORD=paraline_strong_password

# --- ASR Backend ---
ASR_BACKEND=faster_whisper
# Options: faster_whisper | qwen3_asr |sensevoice
# Chỉ đổi dòng này để switch backend, không cần sửa code!

# --- Faster Whisper (dùng khi ASR_BACKEND=faster_whisper) ---
WHISPER_MODEL=small
# Options: tiny | base | small | medium | large-v3 | turbo
WHISPER_DEVICE=cuda     # Đã bật cuda cho Qwen3-ASR
WHISPER_COMPUTE_TYPE=float16   # float16 (GPU) | int8 (CPU)

# --- Qwen3-ASR (dùng khi ASR_BACKEND=qwen3_asr) ---
QWEN_ASR_MODEL=Qwen/Qwen3-ASR-0.6B
# Options: Qwen/Qwen3-ASR-0.6B | Qwen/Qwen3-ASR-1.7B

# --- NLLB Translation ---
NLLB_MODEL=facebook/nllb-200-distilled-600M
# Options: nllb-200-distilled-600M (nhanh) | nllb-200-1.3B (cân bằng) | nllb-200-3.3B (tốt nhất)

# --- Ollama LLM (Intent Classification) ---
LLM_MODEL=llama3:8b
# Options: llama3:8b | gemma3:9b | qwen2.5:7b
# Sau khi `make up`, chạy: make pull-llm

# --- Logging ---
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
